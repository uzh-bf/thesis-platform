{
  "extends": ["@tsconfig/node24/tsconfig.json", "@tsconfig/next/tsconfig.json"],
  "compilerOptions": {
    "moduleResolution": "bundler",
    "paths": {
      "src/*": ["./src/*"]
    },
    "target": "ES2020"
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"],
  "ts-node": {
    "transpileOnly": true,
    "moduleTypes": {
      "prisma/seed.ts": "esm",
      "src/lib/constants.ts": "esm"
    }
  }
}
