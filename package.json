{
  "name": "@uzh-bf/thesis-platform",
  "version": "1.1.0-beta.88",
  "private": true,
  "maintainers": [
    "Roland Schlaefli <roland.schlaefli@df.uzh.ch>"
  ],
  "contributors": [
    "Maximilian Weber <maximilian.weber@df.uzh.ch>"
  ],
  "scripts": {
    "prebuild": "pnpm run prisma:generate",
    "build": "pnpm run build:next",
    "build:next": "next build",
    "predev": "pnpm run prisma:generate",
    "dev": "concurrently \"doppler run --config dev -- next dev\" \"ngrok http 3000 --url=mentally-ace-maggot.ngrok-free.app\"",
    "dev:ibw": "concurrently \"doppler run --config prd_ibw -- next dev\" \"ngrok http 3000 --url=mentally-ace-maggot.ngrok-free.app\"",
    "format": "prettier --write .",
    "lint": "next lint",
    "script:dev": "doppler run --config dev --",
    "script:stage": "doppler run --config stg --",
    "script:prod": "doppler run --config prd --",
    "prisma:deploy": "doppler run --config dev -- prisma migrate deploy",
    "prisma:deploy:stage": "doppler run --config stg -- prisma migrate deploy",
    "prisma:deploy:prod": "doppler run --config prd -- prisma migrate deploy",
    "prisma:deploy:ibw": "doppler run --config prd_ibw -- prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "doppler run --config dev -- prisma migrate dev",
    "prisma:migrate:ibw": "doppler run --config prd_ibw -- prisma migrate dev",
    "prisma:push": "doppler run --config dev -- prisma db push",
    "prisma:push:ibw": "doppler run --config prd_ibw -- prisma db push",
    "prisma:reset": "doppler run --config dev -- prisma migrate reset",
    "prisma:reset:ibw": "doppler run --config prd_ibw -- prisma migrate reset",
    "prisma:studio": "doppler run --config dev -- prisma studio",
    "prisma:studio:ibw": "doppler run --config prd_ibw -- prisma studio",
    "prisma:studio:stage": "doppler run --config stg -- prisma studio",
    "prisma:studio:prod": "doppler run --config prd -- prisma studio",
    "prisma:seed": "doppler run --config dev -- ts-node --project tsconfig.tsnode.json prisma/seed-df.ts",
    "prisma:seed:ibw": "doppler run --config prd_ibw -- ts-node --project tsconfig.tsnode.json prisma/seed-ibw.ts",
    "prisma:setup": "run-s prisma:reset prisma:push prisma:seed",
    "prisma:setup:ibw": "run-s prisma:reset:ibw prisma:push:ibw prisma:seed:ibw",
    "start": "doppler run --config dev -- next start",
    "release:alpha": "standard-version --prerelease alpha --no-verify",
    "release:alpha:dry": "standard-version --dry-run --prerelease alpha",
    "release:beta": "standard-version --prerelease beta --no-verify",
    "release:beta:dry": "standard-version --dry-run --prerelease beta",
    "release:rc": "standard-version --prerelease rc --no-verify",
    "release:rc:dry": "standard-version --dry-run --prerelease rc",
    "release": "standard-version",
    "release:dry": "standard-version --dry-run"
  },
  "dependencies": {
    "@azure/identity": "3.3.0",
    "@azure/storage-blob": "12.15.0",
    "@fortawesome/fontawesome-svg-core": "6.7.2",
    "@fortawesome/free-regular-svg-icons": "6.7.2",
    "@fortawesome/free-solid-svg-icons": "6.7.2",
    "@fortawesome/react-fontawesome": "0.2.2",
    "@microsoft/microsoft-graph-client": "3.0.5",
    "@next-auth/prisma-adapter": "1.0.7",
    "@prisma/client": "6.15.0",
    "@tanstack/react-query": "^5.85.5",
    "@tanstack/react-query-devtools": "^5.85.5",
    "@trpc/client": "11.5.0",
    "@trpc/next": "11.5.0",
    "@trpc/react-query": "11.5.0",
    "@trpc/server": "11.5.0",
    "@types/uuid": "^10.0.0",
    "@uidotdev/usehooks": "2.4.1",
    "@uzh-bf/design-system": "4.0.11",
    "axios": "1.5.1",
    "concurrently": "^9.2.0",
    "cross-fetch": "3.1.5",
    "date-fns": "2.30.0",
    "dotenv-cli": "7.3.0",
    "formik": "2.4.6",
    "jsonwebtoken": "9.0.1",
    "localforage": "1.10.0",
    "next": "15.3.4",
    "next-auth": "4.24.11",
    "nextjs-cors": "2.2.0",
    "node-fetch": "3.3.2",
    "nodemailer": "6.9.4",
    "ramda": "0.29.0",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "react-dropzone": "14.2.3",
    "react-hot-toast": "2.4.1",
    "tailwind-merge": "3.3.1",
    "tailwindcss-radix": "4.0.2",
    "trpc-to-openapi": "^3.0.1",
    "uuid": "^11.0.5",
    "xlsx": "^0.18.5",
    "yup": "1.6.1",
    "zod": "^4.1.3"
  },
  "devDependencies": {
    "@microsoft/microsoft-graph-types": "2.38.0",
    "@tailwindcss/aspect-ratio": "~0.4.2",
    "@tailwindcss/forms": "~0.5.10",
    "@tailwindcss/postcss": "~4.1.12",
    "@tailwindcss/typography": "~0.5.16",
    "@tsconfig/next": "1.0.5",
    "@tsconfig/node18": "2.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/localtunnel": "^2.0.4",
    "@types/node": "^18.8.4",
    "@types/ramda": "^0.29.0",
    "@types/react": "^18.0.21",
    "@types/react-dom": "^18.0.6",
    "autoprefixer": "10.4.15",
    "cssnano": "7.1.1",
    "eslint": "8.48.0",
    "eslint-config-next": "13.4.19",
    "localtunnel": "^2.0.2",
    "npm-run-all": "4.1.5",
    "postcss": "8.4.47",
    "prettier": "3.6.2",
    "prettier-plugin-organize-imports": "3.2.3",
    "prettier-plugin-tailwindcss": "~0.6.14",
    "prisma": "6.15.0",
    "standard-version": "9.5.0",
    "tailwindcss": "~4.1.12",
    "tailwindcss-animate": "~1.0.7",
    "ts-node": "10.9.1",
    "ts-node-dev": "2.0.0",
    "tsx": "^4.19.2",
    "tw-animate-css": "~1.3.4",
    "type-fest": "4.5.0",
    "typescript": "5.9.2"
  },
  "volta": {
    "node": "22.18.0",
    "pnpm": "10.15.0"
  }
}
