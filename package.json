{
  "name": "@uzh-bf/thesis-platform",
  "version": "1.20.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=24.18.0 <25",
    "pnpm": ">=11.9.0 <12"
  },
  "maintainers": [
    "Roland Schlaefli <roland.schlaefli@df.uzh.ch>",
    "Maximilian Weber <maximilian.weber@df.uzh.ch>"
  ],
  "contributors": [
    "Maximilian Weber <maximilian.weber@df.uzh.ch>"
  ],
  "scripts": {
    "prebuild": "pnpm run prisma:generate",
    "build": "pnpm run build:next",
    "build:next": "DATABASE_URL=${DATABASE_URL:-postgresql://localhost:5432/prisma?sslmode=disable} next build",
    "predev": "pnpm run prisma:generate",
    "dev": "next dev",
    "dev:local": "pnpm run prisma:generate && next dev",
    "format": "prettier --write .",
    "lint": "eslint .",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:generate": "DATABASE_URL=${DATABASE_URL:-postgresql://localhost:5432/prisma?sslmode=disable} prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "prisma:reset": "prisma migrate reset",
    "prisma:studio": "prisma studio",
    "prisma:generate:mysql": "DATABASE_URL=${DATABASE_URL:-mysql://localhost:3306/prisma} prisma generate --config prisma.mysql.config.ts",
    "prisma:push:local": "dotenv -e .env.local -- prisma db push",
    "prisma:seed": "ts-node --project tsconfig.tsnode.json prisma/seed-df.ts",
    "prisma:seed:local": "dotenv -e .env.local -- ts-node --project tsconfig.tsnode.json prisma/seed-df.ts",
    "prisma:seed:ibw": "ts-node --project tsconfig.tsnode.json prisma/seed-ibw.ts",
    "prisma:setup": "pnpm run prisma:reset && pnpm run prisma:push && pnpm run prisma:seed",
    "prisma:setup:local": "pnpm run prisma:push:local && pnpm run prisma:seed:local && pnpm run azurite:setup:local",
    "prisma:setup:ibw": "pnpm run prisma:reset && pnpm run prisma:push && pnpm run prisma:seed:ibw",
    "azurite:setup:local": "dotenv -e .env.local -- tsx scripts/setup-azurite.ts",
    "dev:e2e": "dotenv -e .env.local.template -- sh -c 'NEXTAUTH_URL=http://localhost:${PORT:-3100} NEXT_PUBLIC_APP_URL=localhost:${PORT:-3100} next dev -p ${PORT:-3100}'",
    "test:e2e:setup": "dotenv -e .env.local.template -- tsx scripts/setup-e2e.ts",
    "test:e2e": "pnpm run test:e2e:setup && dotenv -e .env.local.template -- playwright test",
    "staging:db:audit": "env THESIS_PLATFORM_ENV=stg ts-node --project tsconfig.tsnode.json scripts/staging-reset-seed.ts --audit-only",
    "staging:db:backup": "env THESIS_PLATFORM_ENV=stg bash scripts/staging-db-backup.sh",
    "staging:db:reset-seed": "env THESIS_PLATFORM_ENV=stg ts-node --project tsconfig.tsnode.json scripts/staging-reset-seed.ts",
    "staging:db:reset-seed:execute": "env THESIS_PLATFORM_ENV=stg ts-node --project tsconfig.tsnode.json scripts/staging-reset-seed.ts --execute",
    "start": "next start",
    "release:alpha": "standard-version --prerelease alpha --no-verify",
    "release:alpha:dry": "standard-version --dry-run --prerelease alpha",
    "release:beta": "standard-version --prerelease beta --no-verify",
    "release:beta:dry": "standard-version --dry-run --prerelease beta",
    "release:rc": "standard-version --prerelease rc --no-verify",
    "release:rc:dry": "standard-version --dry-run --prerelease rc",
    "release": "standard-version",
    "release:dry": "standard-version --dry-run",
    "release:publish": "bash scripts/release-publish.sh"
  },
  "dependencies": {
    "@azure/identity": "4.13.1",
    "@azure/storage-blob": "12.33.0",
    "@fortawesome/fontawesome-svg-core": "7.3.0",
    "@fortawesome/free-regular-svg-icons": "7.3.0",
    "@fortawesome/free-solid-svg-icons": "7.3.0",
    "@fortawesome/react-fontawesome": "3.3.1",
    "@microsoft/microsoft-graph-client": "3.0.7",
    "@next-auth/prisma-adapter": "1.0.7",
    "@prisma/adapter-mariadb": "7.8.0",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@prisma/client-runtime-utils": "7.8.0",
    "@tanstack/react-query": "5.101.2",
    "@tanstack/react-query-devtools": "5.101.2",
    "@trpc/client": "11.18.0",
    "@trpc/next": "11.18.0",
    "@trpc/react-query": "11.18.0",
    "@trpc/server": "11.18.0",
    "@uidotdev/usehooks": "2.4.1",
    "@uzh-bf/design-system": "4.1.6",
    "archiver": "8.0.0",
    "axios": "1.18.1",
    "concurrently": "10.0.3",
    "cross-fetch": "4.1.0",
    "date-fns": "4.4.0",
    "dayjs": "1.11.21",
    "dotenv-cli": "11.0.0",
    "formik": "2.4.9",
    "jsonwebtoken": "9.0.3",
    "localforage": "1.10.0",
    "next": "16.2.10",
    "next-auth": "4.24.14",
    "nextjs-cors": "2.2.1",
    "node-fetch": "3.3.2",
    "ramda": "0.32.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-dropzone": "15.0.0",
    "react-hot-toast": "2.6.0",
    "styled-jsx": "5.1.7",
    "tailwind-merge": "3.6.0",
    "tailwindcss-radix": "4.0.2",
    "trpc-to-openapi": "3.3.0",
    "uuid": "14.0.1",
    "write-excel-file": "4.1.1",
    "yup": "1.7.1",
    "zod": "4.4.3",
    "zod-openapi": "5.4.4"
  },
  "devDependencies": {
    "@microsoft/microsoft-graph-types": "2.43.1",
    "@playwright/test": "1.61.1",
    "@tailwindcss/aspect-ratio": "0.4.2",
    "@tailwindcss/forms": "0.5.11",
    "@tailwindcss/postcss": "4.3.2",
    "@tailwindcss/typography": "0.5.20",
    "@tsconfig/next": "2.0.6",
    "@tsconfig/node24": "24.0.4",
    "@types/archiver": "8.0.0",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "24.13.2",
    "@types/ramda": "0.32.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.5.2",
    "babel-plugin-react-compiler": "1.0.0",
    "cssnano": "8.0.2",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.10",
    "postcss": "8.5.16",
    "prettier": "3.9.4",
    "prettier-plugin-organize-imports": "4.3.0",
    "prettier-plugin-tailwindcss": "0.8.0",
    "prisma": "7.8.0",
    "standard-version": "9.5.0",
    "tailwindcss": "4.3.2",
    "tailwindcss-animate": "1.0.7",
    "ts-node": "10.9.2",
    "ts-node-dev": "2.0.0",
    "tsx": "4.23.0",
    "tw-animate-css": "1.4.0",
    "type-fest": "5.7.0",
    "typescript": "6.0.3"
  },
  "volta": {
    "node": "24.18.0",
    "pnpm": "11.9.0"
  }
}
